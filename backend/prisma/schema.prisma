generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  WORKER
  EMPLOYEE
  ADMIN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Category {
  DEVELOPMENT
  DESIGN
  QA
  DEVOPS
  DOCUMENTATION
}

enum TaskStatus {
  OPEN
  CLAIMED
  COMPLETED
}

// ── Models ─────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  postedTasks  Task[] @relation("PostedBy")
  claimedTasks Task[] @relation("ClaimedBy")

  @@map("users")
}

model Task {
  id             Int        @id @default(autoincrement())
  title          String
  description    String
  priority       Priority
  category       Category
  status         TaskStatus @default(OPEN)
  dueDate        DateTime
  estimatedHours Float
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  createdById Int
  createdBy   User  @relation("PostedBy", fields: [createdById], references: [id])

  claimedById Int?
  claimedBy   User? @relation("ClaimedBy", fields: [claimedById], references: [id])

  @@map("tasks")
}
